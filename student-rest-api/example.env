# Application
APP=dev
PORT=5000
NODE_ENV=development

# Database (required)
DB_DIALECT=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=your_db_name
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# JWT (required)
JWT_ENCRYPTION=your_strong_jwt_secret_here
JWT_EXPIRATION=5h

# Encryption keys
CRYPTOJS_ENCRYPTION_KEY=your_institute_encryption_key
WEBSITE_ENCRYPTION_KEY=your_website_encryption_key
STUDENT_ENCRYPTION_KEY=your_student_encryption_key

# SMTP / Email
SMTP_UserEmail=your_smtp_email@example.com
SMTP_UserPassword=your_smtp_password
SMTP_Host=smtp.example.com
SMTP_Port=587

# AWS / S3
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=ap-south-1
BUCKET=your-s3-bucket-name
CLOUDFRONT=https://your-cloudfront-domain.cloudfront.net
CLOUDFRONTURL=https://your-cloudfront-domain.cloudfront.net
CLOUDFRONTPUBLICKEY=your_cloudfront_public_key_id
EMAILATTATCHMENTSBUCKET=email-attachments-bucket

# Zoom
ZoomAPISecret=your_zoom_api_secret
ZoomAPIKey=your_zoom_api_key

# Twilio
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_NUMBER=+1xxxxxxxxxx

# App URLs
INSTITUTE_DOMAIN=http://app.your-saas-domain.example.com/
Student_Panel=http://student.your-saas-domain.example.com/

# AWS Elastic Transcoder pipeline ID
elasticTranscode=your_elastic_transcoder_pipeline_id

# Chargebee
CHARGEBEESITE=your-chargebee-site-name
CHARGEBEEAPIKEY=your_chargebee_api_key
CHARGEBEE_URL=https://your-site.chargebee.com
CHARGEBEE_API_KEY=your_chargebee_full_access_api_key

# Static files base URL (optional)
STATCI_FILES=
